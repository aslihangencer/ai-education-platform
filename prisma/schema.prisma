generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model StudentRecord {
  id        String   @id @default(cuid())
  name      String
  subject   String
  book      String
  pages     Int
  questions Int
  duration  Int      // Dakika
  createdAt DateTime @default(now())
}
generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
model Student {
  id String @id @default(cuid())
  name String
  book String
  pages Int
  questions Int
}